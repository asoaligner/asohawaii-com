# Formspree form endpoint — forms on /supabase/contact and /supabase submit here.
# Setup:
#   1. Sign up at https://formspree.io (free tier: 50 submissions/month)
#   2. Create a new form, point its delivery email to aso-digital@outlook.com
#   3. Copy the form ID (e.g. "xyzabc123") and replace below
#   4. Copy this file to .env.local (which Next.js reads automatically)
#
# Until this is set, forms render a dev-notice banner and will 404 on submit.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
